PORT=3001

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sistema"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Admin seed
ADMIN_SEED_EMAIL=admin@sistema.local
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_PHONE=+258840000001

# OSRM (motor de rotas)
OSRM_URL=http://localhost:5000

# Cidade alvo (Maputo por defeito; ajustar para Luanda se necessário)
CITY_NAME=maputo
CITY_CENTER_LAT=-25.9692
CITY_CENTER_LNG=32.5732
# bbox: minLng,minLat,maxLng,maxLat
CITY_BBOX=32.45,-26.10,32.75,-25.85

# CORS
ORIGINS=http://localhost:3000,http://localhost:5173

# Email (opcional)
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@sistema.local
EMAIL_SECURE=false
